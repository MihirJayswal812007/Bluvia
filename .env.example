# ============================================================
# BLUVIA — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Supabase (get from: https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay publishable key (safe to expose in frontend)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx

# ============================================================
# Edge Function Secrets (set via Supabase Dashboard → Settings → Edge Functions)
# These are NOT prefixed with VITE_ — they are server-side only
# ============================================================
# RAZORPAY_KEY_SECRET=your-razorpay-secret-key
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (auto-available in edge functions)
